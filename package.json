{
  "name": "luke-ai",
  "version": "1.0.0",
  "private": true,
  "description": "LUKE – AI Legal Research Assistant for Peruvian law",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "worker": "cd backend && celery -A app.workers.celery_app.celery_app worker --loglevel=info",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "docker compose exec postgres psql -U luke -d luke -f /migrations/001_init.sql",
    "seed": "docker compose run --rm backend python scripts/seed.py",
    "stack": "docker compose up --build"
  },
  "engines": {
    "node": ">=20.11"
  }
}

